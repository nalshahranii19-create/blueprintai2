# ============================================================
# Blueprint AI – Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Application
VITE_APP_ID=your_manus_app_id

# OAuth (Manus OAuth Portal)
VITE_OAUTH_PORTAL_URL=https://oauth.manus.app
OAUTH_SERVER_URL=https://oauth.manus.app
OWNER_OPEN_ID=your_owner_open_id

# Database (TiDB / MySQL compatible)
DATABASE_URL=mysql://user:password@host:port/dbname

# Session Security
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# AI / LLM (Manus Built-in Forge API)
BUILT_IN_FORGE_API_URL=https://api.manus.app/forge
BUILT_IN_FORGE_API_KEY=your_forge_api_key
